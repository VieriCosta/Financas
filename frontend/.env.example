# Opcional. Se vazio, o frontend usa automaticamente o mesmo host da pagina na porta 3333.
# Exemplo abrindo em http://192.168.1.73:5173: usa http://192.168.1.73:3333/api
VITE_API_URL=

# Forcar localhost:
# VITE_API_URL=http://localhost:3333/api

# Forcar rede local:
# VITE_API_URL=http://192.168.1.73:3333/api

# Producao:
# VITE_API_URL=https://sua-api.onrender.com/api
